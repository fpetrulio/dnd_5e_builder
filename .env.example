# Copia questo file in .env e compila i valori

# Backend
DATABASE_URL=sqlite+aiosqlite:///./data/dnd_builder.db
DEBUG=false

# AI — ottieni la chiave su https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# CORS — aggiungi l'IP del tuo dispositivo locale se accedi da telefono
# es: CORS_ORIGINS=["http://localhost:5173","http://192.168.1.10:5173"]
CORS_ORIGINS=["http://localhost:5173","http://localhost:80"]

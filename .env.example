# Copia questo file in .env e compila i valori

# Backend
DATABASE_URL=sqlite+aiosqlite:///./data/dnd_builder.db
DEBUG=false

# AI — get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# CORS — add your local device IP if accessing from phone
# e.g. CORS_ORIGINS=["http://localhost:5173","http://192.168.1.10:5173"]
CORS_ORIGINS=["http://localhost:5173","http://localhost:80"]
